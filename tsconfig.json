{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "paths": {
      "@agentbus/protocol": ["./protocol/src/index.ts"]
    }
  },
  "include": ["protocol/**/*.ts", "host/**/*.ts"]
}
